# Google OAuth2 Client ID — required for Google Drive export (OUT-04)
# Get from: Google Cloud Console > APIs & Services > Credentials > OAuth 2.0 Client ID
# Authorized JavaScript origins must include: http://localhost:5173
# Note: The user already has a Client ID configured for localhost:5173
VITE_GOOGLE_CLIENT_ID=your-client-id-here.apps.googleusercontent.com
